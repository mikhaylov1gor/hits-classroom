					"name": "Get feed",
					"request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}], "url": "{{baseUrl}}/api/v1/courses/{{courseId}}/feed"}
				},
				{
					"name": "Detach submission",
					"event": [{"listen": "test", "script": {"exec": ["if (pm.response.code === 200) {", "    const b = pm.response.json();", "    console.log('Submission after detach:', {", "        id: b.id,", "        is_attached: b.is_attached,", "        grade: b.grade,", "        grade_comment: b.grade_comment", "    });", "}"], "type": "text/javascript"}}],
					"request": {
						"method": "PUT",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": "{{baseUrl}}/api/v1/courses/{{courseId}}/assignments/{{assignmentId}}/detach"
					}
				},
				{
					"name": "Return submission for rework",
					"event": [{"listen": "test", "script": {"exec": ["if (pm.response.code === 200) {", "    const b = pm.response.json();", "    console.log('Submission marked as returned:', {", "        id: b.id,", "        is_attached: b.is_attached,", "        is_returned: b.is_returned", "    });", "}"], "type": "text/javascript"}}],
					"request": {
						"method": "PUT",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}, {"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{}"},
						"url": "{{baseUrl}}/api/v1/courses/{{courseId}}/assignments/{{assignmentId}}/submissions/{{submissionId}}/return"
					}
				},
				{
					"name": "Save draft (is_attached=false)",
					"event": [{"listen": "test", "script": {"exec": ["if (pm.response.code === 201 || pm.response.code === 200) {", "    const b = pm.response.json();", "    console.log('Draft saved:', {", "        id: b.id,", "        is_attached: b.is_attached,", "        is_returned: b.is_returned", "    });", "}"], "type": "text/javascript"}}],
					"request": {
						"method": "POST",
						"header": [{"key": "Authorization", "value": "Bearer {{studentToken}}"}, {"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\n  \"body\": \"Черновик решения...\",\n  \"file_ids\": [],\n  \"is_attached\": false\n}"},
						"url": "{{baseUrl}}/api/v1/courses/{{courseId}}/assignments/{{assignmentId}}/submissions"
					}
				},
				{
					"name": "Submit final (is_attached=true)",
					"event": [{"listen": "test", "script": {"exec": ["if (pm.response.code === 201 || pm.response.code === 200) {", "    const b = pm.response.json();", "    console.log('Submission finalized:', {", "        id: b.id,", "        is_attached: b.is_attached,", "        is_returned: b.is_returned", "    });", "}"], "type": "text/javascript"}}],
					"request": {
						"method": "POST",
						"header": [{"key": "Authorization", "value": "Bearer {{studentToken}}"}, {"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\n  \"body\": \"Финальное решение.\",\n  \"file_ids\": [],\n  \"is_attached\": true\n}"},
						"url": "{{baseUrl}}/api/v1/courses/{{courseId}}/assignments/{{assignmentId}}/submissions"
					}
				},
				{
					"name": "Upload file",
					"event": [{"listen": "test", "script": {"exec": ["if (pm.response.code === 201) {", "    const b = pm.response.json();", "    console.log('File uploaded:', {", "        id: b.id,", "        file_name: b.file_name,", "        file_size: b.file_size,", "        mime_type: b.mime_type", "    });", "}"], "type": "text/javascript"}}],
					"request": {
						"method": "POST",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"body": {"mode": "formdata", "formdata": [{"key": "file", "type": "file", "src": []}]},
						"url": "{{baseUrl}}/api/v1/files"
					}
				},
				{
					"name": "List user files",
					"event": [{"listen": "test", "script": {"exec": ["if (pm.response.code === 200) {", "    const arr = pm.response.json();", "    const count = Array.isArray(arr) ? arr.length : 0;", "    console.log('User files:', count);", "    arr.forEach(f => {", "        console.log(`- ${f.file_name} (${f.file_size} bytes, ${f.mime_type})`);", "    });", "}"], "type": "text/javascript"}}],
					"request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}], "url": "{{baseUrl}}/api/v1/users/{{userId}}/files"}
				},
				{
					"name": "Download file",
					"request": {"method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{token}}"}], "url": "{{baseUrl}}/api/v1/files/{{fileId}}"}
				}
			]
		}
	]
}
					