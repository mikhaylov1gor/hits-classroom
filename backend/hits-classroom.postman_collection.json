					"request": {"method": "GET", "header": [], "url": "{{baseUrl}}/health"}
				},
				{
					"name": "02 Register (teacher)",
					"event": [{"listen": "test", "script": {"exec": ["if (pm.response.code === 201) {", "    const b = pm.response.json();", "    if (b.id) pm.collectionVariables.set('userId', b.id);", "    if (b.email) pm.collectionVariables.set('userEmail', b.email);", "}"], "type": "text/javascript"}}],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\n  \"email\": \"teacher@test.com\",\n  \"password\": \"password12\",\n  \"first_name\": \"Teacher\",\n  \"last_name\": \"One\",\n  \"birth_date\": \"1990-01-15\"\n}"},
						"url": "{{baseUrl}}/api/v1/auth/register"
					}
				},
				{
					"name": "03 Login (teacher)",
					"event": [{"listen": "test", "script": {"exec": ["if (pm.response.code === 200) {", "    const b = pm.response.json();", "    if (b.token) pm.collectionVariables.set('token', b.token);", "    if (b.user && b.user.id) pm.collectionVariables.set('userId', b.user.id);", "}"], "type": "text/javascript"}}],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {"mode": "raw", "raw": "{\n  \"email\": \"teacher@test.com\",\n  \"password\": \"password12\"\n}"},
						"url": "{{baseUrl}}/api/v1/auth/login"
					}
				},
				{
					"name": "04 Get me",
					"event": [{"listen": "test", "script": {"exec": ["if (pm.response.code === 200) {", "    const b = pm.response.json();", "    if (b.id) pm.collectionVariables.set('userId', b.id);", "    if (b.email) pm.collectionVariables.set('userEmail', b.email);", "}"], "type": "text/javascript"}}],
